{
	"name": "codebase-rag-tui",
	"version": "0.2.0",
	"description": "Terminal-based AI agent for codebase RAG (Retrieval-Augmented Generation)",
	"license": "MIT",
	"author": "johnsonafool",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/johnsonafool/codebase-rag-tui.git"
	},
	"homepage": "https://github.com/johnsonafool/codebase-rag-tui#readme",
	"bugs": {
		"url": "https://github.com/johnsonafool/codebase-rag-tui/issues"
	},
	"keywords": [
		"cli",
		"terminal",
		"ai",
		"rag",
		"codebase",
		"tui",
		"ink",
		"react"
	],
	"bin": {
		"codebase-rag-tui": "dist/cli.js"
	},
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"prepublishOnly": "pnpm build",
		"test": "prettier --check . && xo && ava"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"dotenv": "^17.2.4",
		"ink": "^4.1.0",
		"ink-markdown-es": "^1.1.0",
		"ink-select-input": "^6.2.0",
		"ink-text-input": "^6.0.0",
		"meow": "^11.0.0",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3"
	},
    "peerDependencies": {
        "react": "^18.2.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": false
        }
    },
	"devDependencies": {
		"react": "^18.2.0",
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
